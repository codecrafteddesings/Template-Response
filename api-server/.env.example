# ODBC Connection String
ODBC_CONN=Driver={IBM i Access ODBC Driver};System=pub400.com;Uid=YOUR_USER;Pwd=YOUR_PASS;DBQ=pub400;SSL=0;

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug